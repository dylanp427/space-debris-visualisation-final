{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": 480,
  "height": 480,
  "data": {"url": "https://raw.githubusercontent.com/dylanp427/Space-junk/refs/heads/main/satcat.csv"},
  "background": "black",
  "title": {"text":"Distribution of orbits of different pieces of space junk","color":"#ffaa44","fontSize":16,
  "subtitle":"Space junk follows a variety of orbital paths, some altitudes like Geostationary are very cluttered",
  "subtitleColor":"white","subtitleFontSize":12,"anchor":"middle","frame":"group"},
  "params": [
    {
      "name": "ObjectType",
      "value": "DEB",
      "bind": {
        "input": "select",
        "name": "Object Type: ",
        "options": [
          "DEB",
          "PAY",
          "R/B"
        ]
      }
    }
  ],

  "transform": [
    {"filter": "datum.OBJECT_TYPE==ObjectType"}
  ],
  "mark": {"type":"circle","size":1},
  "encoding": {
    "x": {"field": "PERIGEE", "type": "quantitative","scale": {
        "domain": [100, 100000], "type":"log"
      }},
    "y": {"field": "APOGEE", "type": "quantitative","scale": {
        "domain": [100, 100000], "type":"log"
      }},
    "color": {"field": "INCLINATION", "type": "quantitative","scale":{"domain":[1,80,100]}}
    
    
  },
  "config": {
    "title": {
      "color": "white",
      "subtitleColor": "white"
    },
    "legend": {
      "titleColor": "white",
      "labelColor": "white"
    },
    "axis":{
      "titleColor": "white",
      "labelColor": "white"
    }
  }
}