
{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "A scatterplot showing space debris events over time by altitude with object labels on hover.",
  "title": {"text":"Space debris events by altitude","color":"#ffaa44","fontSize":16,
  "subtitle":"Event distribution over time at various orbital altitudes","subtitleColor":"white","subtitleFontSize":11,"anchor":"middle","offset":20},
  "width": 320,
  "height": 220,
  "autosize": {"type": "pad", "contains": "padding"},
  "data": {
    "url": "https://raw.githubusercontent.com/dylanp427/-space-debris-visualization/main/fragmentscleaned.csv"
  },
  "encoding": {
    "x": {"field": "event_date", "type": "temporal", "title": "Event Date"},
    "y": {"field": "altitude_km", "type": "quantitative", "title": "Altitude (km)", "scale":{"type":"log"}}
  },
  "config": {
    "background": "black",
    "title": {
      "color": "white",
      "subtitleColor": "white"
    },
    "legend": {
      "titleColor": "white",
      "labelColor": "white"
    },
    "axis":{
      "titleColor": "white",
      "labelColor": "white"
    }
  },
  "layer": [
    {
      "name": "points",
      "params": [
        {
          "name": "hover",
          "select": {
            "type": "point",
            "on": "mouseover",
            "clear": "mouseout"
          }
        }
      ],
      "mark": {"type": "point", "filled": true, "size": 60}
    },
    {
      "name": "labels",
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 7,
        "dy": -2,
        "color":"white"
      },
      "encoding": {
        "text": {"field": "object_name", "type": "nominal"},
        "opacity": {
          "condition": {
            "param": "hover",
            "value": 1,
            "empty": false
          },
          "value": 0
        }
      }
    }
  ]
}
