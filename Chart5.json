{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "A simple pie chart",
  "title": {"text":"Origin of different types of space junk","color":"#ffaa44","fontSize":16,
  "subtitle":"Space junk comes from a variety of origins, the main ones are from anomalous causes, propulsion and unknown causes.",
  "subtitleColor":"white","subtitleFontSize":11,"anchor":"middle","offset":20},
  "background": "black",
"width": 400,
"height": 200,
  "params": [
    {
      "name": "Timeline",
      "value": "All",
      "bind": {
        "input": "select",
        "name": "Timeline: ",
        "options": [
          "All",
          "Past 10 years"
        ]
      }
    }
  ],
  

  "data": {
    "values": [
      {"category": "Anomalous", "value": 116 , "zeit":"All"},
      {"category": "Populsion", "value": 155 , "zeit":"All"},
      {"category": "Deliberate", "value": 108 , "zeit":"All"},
      {"category": "Accidental", "value": 25 , "zeit":"All"},
      {"category": "Aerodynamics", "value": 32 , "zeit":"All"},
      {"category": "Small impactor", "value": 10 , "zeit":"All"},
      {"category": "Electrical", "value": 25 , "zeit":"All"},
      {"category": "Unknown", "value": 108 , "zeit":"All"},
      {"category": "Collision", "value": 5 , "zeit":"All"},

      {"category": "Anomalous", "value": 17 , "zeit":"Past 10 years"},
      {"category": "Populsion", "value": 31 , "zeit":"Past 10 years"},
      {"category": "Deliberate", "value": 1 , "zeit":"Past 10 years"},
      {"category": "Accidental", "value": 2 , "zeit":"Past 10 years"},
      {"category": "Aerodynamics", "value": 5 , "zeit":"Past 10 years"},
      {"category": "Small impactor", "value": 5 , "zeit":"Past 10 years"},
      {"category": "Electrical", "value": 5 , "zeit":"Past 10 years"},
      {"category": "Unknown", "value": 27 , "zeit":"Past 10 years"},
      {"category": "Collision", "value": 0 , "zeit":"Past 10 years"}
      
    ]
  },
  "transform": [
    {"filter": "datum.zeit==Timeline"}
  ],
  "mark": {"type": "arc", "innerRadius": 0},
  "encoding": {
    "theta": {"field": "value", "type": "quantitative", "stack": true},
    "color": {"field": "category", "type": "nominal"}
  },
  "config": {
    "title": {
      "color": "white",
      "subtitleColor": "white"
    },
    "legend": {
      "titleColor": "white",
      "labelColor": "white"
    },
    "axis":{
      "titleColor": "white",
      "labelColor": "white"
    }
  }
}